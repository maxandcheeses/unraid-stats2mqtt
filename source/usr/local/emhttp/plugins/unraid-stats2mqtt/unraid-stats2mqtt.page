function ummFormToYaml() {
  var sections = [
    { comment: '# Plugin', fields: ['PLUGIN_ENABLED'] },
    { comment: '# Unraid API', fields: ['UNRAID_API_KEY','UNRAID_API_HOST'] },
    { comment: '# MQTT Connection', fields: ['MQTT_PROTOCOL','MQTT_HOST','MQTT_PORT','MQTT_USER','MQTT_PASS','MQTT_TLS_INSECURE'] },
    { comment: '# Device Identity', fields: ['MQTT_DEVICE_NAME','MQTT_DEVICE_ID','MQTT_BASE_TOPIC'] },
    { comment: '# Home Assistant', fields: ['HA_WATCH_STATUS','HA_STATUS_TOPIC','HA_DISCOVERY_TOPIC'] },
    { comment: '# Metrics — Array & System', fields: [
      'INTERVAL_ARRAY_STATUS','EXPIRE_ARRAY_STATUS','RETAIN_ARRAY_STATUS',
      'INTERVAL_ARRAY_SUMMARY','EXPIRE_ARRAY_SUMMARY','RETAIN_ARRAY_SUMMARY',
      'INTERVAL_CACHE','EXPIRE_CACHE','RETAIN_CACHE',
      'INTERVAL_PARITY','EXPIRE_PARITY','RETAIN_PARITY',
      'INTERVAL_REBUILD','EXPIRE_REBUILD','RETAIN_REBUILD',
      'INTERVAL_SYSTEM_INFO','EXPIRE_SYSTEM_INFO','RETAIN_SYSTEM_INFO',
      'INTERVAL_UPDATE_AVAILABLE','EXPIRE_UPDATE_AVAILABLE','RETAIN_UPDATE_AVAILABLE',
      'INTERVAL_UPTIME','EXPIRE_UPTIME','RETAIN_UPTIME',
    ]},
    { comment: '# Metrics — Disks', fields: [
      'INTERVAL_DISK_TEMPS','EXPIRE_DISK_TEMPS','RETAIN_DISK_TEMPS',
      'INTERVAL_DISK_STATES','EXPIRE_DISK_STATES','RETAIN_DISK_STATES',
      'INTERVAL_DISK_USAGE','EXPIRE_DISK_USAGE','RETAIN_DISK_USAGE',
      'INTERVAL_DISK_ERRORS','EXPIRE_DISK_ERRORS','RETAIN_DISK_ERRORS',
      'INTERVAL_RW_SPEEDS','EXPIRE_RW_SPEEDS','RETAIN_RW_SPEEDS',
    ]},
    { comment: '# Metrics — Monitor', fields: [
      'INTERVAL_MONITOR','EXPIRE_MONITOR','RETAIN_MONITOR',
    ]},
    { comment: '# Metrics — Network', fields: [
      'INTERVAL_NETWORK','EXPIRE_NETWORK','RETAIN_NETWORK',
    ]},
    { comment: '# Metrics — Shares', fields: [
      'INTERVAL_SHARES','EXPIRE_SHARES','RETAIN_SHARES',
    ]},
    { comment: '# Metrics — Docker', fields: [
      'INTERVAL_DOCKER','EXPIRE_DOCKER','RETAIN_DOCKER',
      'DOCKER_SENSOR_MODE','DOCKER_SENSORS',
    ]},
    { comment: '# Metrics — VMs', fields: [
      'INTERVAL_VMS','EXPIRE_VMS','RETAIN_VMS',
      'VM_SENSOR_MODE','VM_SENSORS',
    ]},
  ];
  var lines = ['# unraid-stats2mqtt config'];
  sections.forEach(function(sec) {
    lines.push('');
    lines.push(sec.comment);
    sec.fields.forEach(function(name) {
      var el = document.querySelector('[name="' + name + '"]');
      if (!el) return;
      var val = el.value || '';
      lines.push(name + ': "' + val.replace(/\\/g, '\\\\').replace(/"/g, '\\"') + '"');
    });
  });
  return lines.join('\n');
}

function ummYamlToForm(yaml) {
  var map = {};
  yaml.split('\n').forEach(function(line) {
    line = line.trim();
    if (!line || line[0] === '#') return;
    var m = line.match(/^([A-Z0-9_]+):\s*"?(.*?)"?\s*$/);
    if (m) map[m[1]] = m[2].replace(/\\"/g, '"').replace(/\\\\/g, '\\');
  });
  UMM_YAML_FIELDS.forEach(function(name) {
    var el = document.querySelector('[name="' + name + '"]');
    if (el && map[name] !== undefined) el.value = map[name];
  });
  // Re-sync dependent UI
  updateTLS();
}

function ummSwitchView(view) {
  if (view === UMM_VIEW) return;
  if (view === 'yaml') {
    document.getElementById('umm-yaml-textarea').value = ummFormToYaml();
    document.getElementById('umm-form-view').style.display = 'none';
    document.getElementById('umm-yaml-view').style.display  = '';
    document.getElementById('umm-btn-form').classList.remove('active');
    document.getElementById('umm-btn-yaml').classList.add('active');
  } else {
    var yaml = document.getElementById('umm-yaml-textarea').value;
    ummYamlToForm(yaml);
    document.getElementById('umm-yaml-view').style.display  = 'none';
    document.getElementById('umm-form-view').style.display  = '';
    document.getElementById('umm-btn-yaml').classList.remove('active');
    document.getElementById('umm-btn-form').classList.add('active');
  }
  UMM_VIEW = view;
}

// Override save to handle YAML mode
(function() {
  var form = document.querySelector('form');
  if (!form) return;
  var origSubmit = form.onsubmit;
  form.addEventListener('submit', function(e) {
    if (UMM_VIEW !== 'yaml') return; // let ummSaveAndRestart handle form mode
    e.preventDefault();
    var yaml = document.getElementById('umm-yaml-textarea').value;
    ummPost({ action: 'save_yaml', yaml: yaml }, function(msg) {
      var isErr = ummIsErr(msg);
      ummToast(msg, isErr ? 'error' : 'success');
      if (!isErr) {
        var yaml = document.getElementById('umm-yaml-textarea').value;
        var enabledMatch = yaml.match(/^PLUGIN_ENABLED:\s*"?(\w+)"?/m);
        var yamlEnabled = enabledMatch ? enabledMatch[1] : 'true';
        var yamlAction = yamlEnabled === 'false' ? 'daemon_stop' : 'daemon_restart';
        ummSetPendingRestart();
        fetch(UMM_EXEC, {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams({ action: yamlAction, csrf_token: UMM_CSRF }),
          credentials: 'same-origin'
        }).then(function() { ummClearPendingRestart(); });
        setTimeout(function() { window.location.reload(); }, 2500);
      }
    });
  }, true);
})();

function ummRevealClick(e, input) {
  if (e.offsetX >= input.offsetWidth - 24) {
    var shown = input.type === 'text';
    input.type = shown ? 'password' : 'text';
    input.classList.toggle('umm-revealed', !shown);
  }
}
function ummToggleReveal(id, btn) {
  var input = document.getElementById(id);
  if (!input) return;
  var shown = input.type === 'text';
  input.type = shown ? 'password' : 'text';
  input.classList.toggle('umm-revealed', !shown);
  if (btn) btn.style.opacity = shown ? '' : '1';
}

function ummGenerateApiKey(btn) {
  var lbl   = document.getElementById('umm-apikey-result');
  var input = document.getElementById('unraid_api_key');
  if (btn) btn.disabled = true;
  if (lbl) { lbl.textContent = 'Generating…'; lbl.style.color = 'inherit'; lbl.style.opacity = '1'; }
  ummPost({ action: 'generate_api_key' }, function(raw) {
    if (btn) btn.disabled = false;
    var data = {};
    try { data = JSON.parse(raw); } catch(e) {}
    if (!lbl) return;
    if (data.ok && data.key) {
      if (input) input.value = data.key;
      lbl.textContent = '✓ Key populated — save settings to apply';
      lbl.style.color = 'var(--umm-success)';
    } else {
      lbl.textContent = '✗ ' + (data.msg || 'Failed to generate key');
      lbl.style.color = 'var(--umm-error)';
    }
    lbl.style.opacity = '1';
    clearTimeout(lbl._hideTimer);
    lbl._hideTimer = setTimeout(function() { lbl.style.opacity = '0'; }, 6000);
  });
}

function ummTestConnection(btn) {
  var lbl = document.getElementById('umm-conn-result');
  if (btn) btn.disabled = true;
  if (lbl) { lbl.textContent = '…'; lbl.style.color = 'inherit'; lbl.style.opacity = '1'; }
  ummPost({ action: 'test_connection' }, function(msg) {
    if (btn) btn.disabled = false;
    if (!lbl) return;
    var isErr = ummIsErr(msg);
    lbl.textContent = isErr ? '✗ ' + msg : '✓ Connected';
    lbl.style.color = isErr ? 'var(--umm-error)' : 'var(--umm-success)';
    lbl.style.opacity = '1';
    ummLogAppend(msg);
    clearTimeout(lbl._hideTimer);
    lbl._hideTimer = setTimeout(function() { lbl.style.opacity = '0'; }, 5000);
  });
}

function ummEntityToggle(group) {
  var cbs   = document.querySelectorAll('.umm-' + group + '-cb');
  var names = [];
  cbs.forEach(function(cb) { if (cb.checked) names.push(cb.dataset.name); });
  var input = document.getElementById(group + '-sensors-input');
  if (input) input.value = names.join(',');
}

function ummEntityModeChange(group, mode) {
  var note = document.getElementById(group + '-exclude-note');
  if (note) note.style.display = mode === 'exclude' ? 'block' : 'none';
}

// Restore pending-restart indicator if set before last page unload.
// If the daemon is already running (e.g. after a plugin update), treat that as
// a completed restart and clear the flag instead.
(function() {
  if (!localStorage.getItem('umm_pending_restart')) return;
  var daemonRunning = <?= $daemon_running ? 'true' : 'false' ?>;
  if (daemonRunning) ummClearPendingRestart();
  else ummSetPendingRestart();
})();

(function() {
  var _logPoll = null;
  function startLogPoll() {
    if (_logPoll) return;
    _logPoll = setInterval(ummRefreshLogs, 3000);
  }
  function stopLogPoll() {
    clearInterval(_logPoll);
    _logPoll = null;
  }
  var box = document.getElementById('umm-log-box');
  if (box) {
    box.addEventListener('mouseenter', stopLogPoll);
    box.addEventListener('mouseleave', startLogPoll);
  }
  startLogPoll();
})();
</script>
