<script>
var UMM_EXEC = '/plugins/unraid-stats2mqtt/include/exec.php';
var UMM_CSRF = '<?= htmlspecialchars($var['csrf_token'] ?? '', ENT_QUOTES) ?>';

function ummToast(msg, type) {
  var t = document.getElementById('umm-toast');
  t.textContent = msg;
  t.className = 'umm-toast ' + type + ' show';
  setTimeout(function() { t.classList.remove('show'); }, 4000);
}

function ummLogAppend(msg) {
  var box = document.querySelector('.umm-log-box');
  if (!box) return;
  var ts = new Date().toLocaleTimeString();
  box.textContent += '\n[' + ts + '] ' + msg;
  box.scrollTop = box.scrollHeight;
}

var UMM_NO_RELOAD = { test: true, test_connection: true, set_enabled: true, clear_logs: true, generate_api_key: true };
var UMM_LOG_ONLY  = { test: true, test_connection: true };

function ummIsErr(msg) {
  var m = msg.toLowerCase();
  return m.indexOf('fail') !== -1 || m.indexOf('error') !== -1 || m.indexOf('not found') !== -1;
}

function ummPost(params, onSuccess, onError) {
  params['csrf_token'] = UMM_CSRF;
  fetch(UMM_EXEC, {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: new URLSearchParams(params),
    credentials: 'same-origin'
  })
  .then(function(r) {
    if (!r.ok) throw new Error('HTTP ' + r.status);
    return r.text();
  })
  .then(onSuccess)
  .catch(function(err) { if (onError) onError(err); else ummToast('Request failed: ' + err, 'error'); });
}

function ummSetPendingRestart() {
  localStorage.setItem('umm_pending_restart', '1');
  var btn  = document.getElementById('umm-restart-btn');
  var note = document.getElementById('umm-restart-note');
  if (btn)  { btn.classList.remove('umm-btn-muted'); btn.classList.add('umm-btn-danger'); }
  if (note) note.style.display = '';
}

function ummClearPendingRestart() {
  localStorage.removeItem('umm_pending_restart');
  var btn  = document.getElementById('umm-restart-btn');
  var note = document.getElementById('umm-restart-note');
  if (btn)  { btn.classList.remove('umm-btn-danger'); btn.classList.add('umm-btn-muted'); }
  if (note) note.style.display = 'none';
}

function ummDaemonToggle(action) {
  var statusEl = document.getElementById('umm-daemon-status');
  var pidEl    = document.getElementById('umm-daemon-pid');
  var btn      = document.getElementById('umm-daemon-btn');
  if (btn) btn.disabled = true;
  if (statusEl) statusEl.textContent = action === 'daemon_start' ? 'Starting…' : 'Stopping…';
  if (pidEl) pidEl.textContent = '';
  ummPost({ action: action }, function(msg) {
    var isErr = ummIsErr(msg);
    if (isErr) {
      if (statusEl) statusEl.textContent = msg;
      if (btn) btn.disabled = false;
    } else {
      if (action === 'daemon_restart' || action === 'daemon_start') ummClearPendingRestart();
      setTimeout(function() { window.location.reload(); }, 3000);
    }
  });
}

function ummAction(data) {
  ummPost(data, function(msg) {
    if (UMM_LOG_ONLY[data.action]) {
      ummLogAppend(msg);
      return;
    }
    var isErr = ummIsErr(msg);
    ummToast(msg, isErr ? 'error' : 'success');
    if (!isErr && !UMM_NO_RELOAD[data.action]) setTimeout(function() { window.location.reload(); }, 1500);
  });
}

function ummSetEnabled(val) {
  var hidden = document.getElementById('umm-plugin-enabled-field');
  if (hidden) hidden.value = val;
  ummPost({ action: 'set_enabled', enabled: val }, function(msg) {
    ummToast(msg, ummIsErr(msg) ? 'error' : 'success');
  });
}

function ummUploadCert(field, input) {
  if (!input.files || !input.files[0]) return;
  var fd = new FormData();
  fd.append('action', 'upload_cert');
  fd.append('csrf_token', UMM_CSRF);
  fd.append(field, input.files[0]);
  fetch(UMM_EXEC, { method: 'POST', body: fd, credentials: 'same-origin' })
    .then(function(r) {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.text();
    })
    .then(function(msg) {
      ummToast(msg, ummIsErr(msg) ? 'error' : 'success');
      setTimeout(function() { window.location.reload(); }, 1500);
    })
    .catch(function(err) { ummToast('Upload failed: ' + err, 'error'); });
}

function ummSanitizeDeviceId() {
  var el = document.getElementById('mqtt_device_id');
  if (el) el.value = el.value.toLowerCase().replace(/[^a-z0-9_]/g, '_');
}

function ummSaveAndRestart(e) {
  if (UMM_VIEW === 'yaml') { e.preventDefault(); return false; }
  ummSanitizeDeviceId();
  var enabled = (document.getElementById('umm-plugin-enabled-field') || {}).value ?? 'true';
  var action = enabled === 'false' ? 'daemon_stop' : 'daemon_restart';
  ummSetPendingRestart();
  setTimeout(function() {
    fetch(UMM_EXEC, {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams({ action: action, csrf_token: UMM_CSRF }),
      credentials: 'same-origin'
    }).then(function() { ummClearPendingRestart(); });
    setTimeout(function() { window.location.reload(); }, 2000);
  }, 1200);
  return true;
}

function updateTLS() {
  var proto = document.getElementById('proto_select').value;
  var tls   = document.getElementById('tls_section');
  tls.classList.toggle('hidden', proto !== 'mqtts' && proto !== 'wss');
}

function ummRefreshLogs() {
  var lines = document.getElementById('umm-log-lines').value;
  ummPost({ action: 'get_logs', lines: lines }, function(text) {
    var box = document.getElementById('umm-log-box');
    if (box) { box.textContent = text; box.scrollTop = box.scrollHeight; }
  });
}

function ummClearLogs() {
  ummPost({ action: 'clear_logs' }, function(msg) {
    var isErr = ummIsErr(msg);
    ummToast(msg, isErr ? 'error' : 'success');
    if (!isErr) {
      var box = document.getElementById('umm-log-box');
      if (box) box.textContent = '';
    }
  });
}

// ── View toggle: Form ↔ YAML ──────────────────────────────────────────────
var UMM_VIEW = 'form';

var UMM_YAML_FIELDS = [
  // Unraid API
