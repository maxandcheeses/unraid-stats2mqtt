  'INTERVAL_ARRAY_STATUS','EXPIRE_ARRAY_STATUS','RETAIN_ARRAY_STATUS',
  'INTERVAL_ARRAY_SUMMARY','EXPIRE_ARRAY_SUMMARY','RETAIN_ARRAY_SUMMARY',
  'INTERVAL_CACHE','EXPIRE_CACHE','RETAIN_CACHE',
  'INTERVAL_PARITY','EXPIRE_PARITY','RETAIN_PARITY',
  'INTERVAL_REBUILD','EXPIRE_REBUILD','RETAIN_REBUILD',
  'INTERVAL_SYSTEM_INFO','EXPIRE_SYSTEM_INFO','RETAIN_SYSTEM_INFO',
  'INTERVAL_UPDATE_AVAILABLE','EXPIRE_UPDATE_AVAILABLE','RETAIN_UPDATE_AVAILABLE',
  'INTERVAL_UPTIME','EXPIRE_UPTIME','RETAIN_UPTIME',
  // Disks
  'INTERVAL_DISK_TEMPS','EXPIRE_DISK_TEMPS','RETAIN_DISK_TEMPS',
  'INTERVAL_DISK_STATES','EXPIRE_DISK_STATES','RETAIN_DISK_STATES',
  'INTERVAL_DISK_USAGE','EXPIRE_DISK_USAGE','RETAIN_DISK_USAGE',
  'INTERVAL_DISK_ERRORS','EXPIRE_DISK_ERRORS','RETAIN_DISK_ERRORS',
